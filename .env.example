
# ===== 基本 =====
DOMAIN=example.com
REVERSE_ZONE=1.168.192.in-addr.arpa

# ===== dnsdist =====
DNSDIST_LISTEN_V4=0.0.0.0:53
DNSDIST_ACL=192.168.1.0/24,203.0.113.10/32,127.0.0.1/32
DNSDIST_WEB_LISTEN=0.0.0.0:8083
DNSDIST_WEB_PASSWORD=ChangeMeDnsdist
DNSDIST_WEB_ACL=192.168.1.0/24,127.0.0.1/32

# ===== recursor =====
RECURSOR_LOCAL_ADDRESS=0.0.0.0
RECURSOR_LOCAL_PORT=53
RECURSOR_ALLOW_FROM=192.168.1.0/24,127.0.0.1/32
RECURSOR_DNSSEC_MODE=validate

# 内部ゾーン → 権威へ
RECURSOR_INTERNAL_ZONES=example.com=pdns-auth:53;1.168.192.in-addr.arpa=pdns-auth:53

# 外部（.） → 上流（IPv4×2, IPv6×2）
RECURSOR_FORWARD_MODE=forward-external
RECURSOR_FORWARDERS_V4=9.9.9.9:53;1.1.1.1:53
RECURSOR_FORWARDERS_V6=[2620:fe::fe]:53;[2606:4700:4700::1111]:53

# ===== PowerDNS-Auth =====
PDNS_AUTH_API_KEY=ChangeMeAuthApiKey
PDNS_AUTH_WEB_BIND=0.0.0.0
PDNS_AUTH_WEB_PORT=8081
PDNS_AUTH_WEB_ACL=192.168.1.0/24,127.0.0.1/32

# ===== PowerDNS-Admin =====
PDA_SECRET_KEY=ChangeMeVeryLongRandomString
PDA_SQLALCHEMY_DATABASE_URI=sqlite:////data/pdnsadmin.sqlite
PDA_PORT=9191

# ===== dnsdist rate limiting（静的） =====
DNSDIST_RL_TC_QPS=200
DNSDIST_RL_DROP_QPS=500
DNSDIST_RL_GLOBAL_QPS=50000

# ===== dnsdist rate limiting（動的） =====
DNSDIST_DYN_QPS=300
DNSDIST_DYN_WINDOW=10
DNSDIST_DYN_BLOCK_SEC=60
DNSDIST_RINGBUF=100000
